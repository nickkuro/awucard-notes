# Copy this to .env and fill in real values. Never commit .env.

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
SESSION_SECRET=

# Optional: comma-separated Discord IDs allowed to log in. Leave blank for anyone.
ALLOWED_DISCORD_IDS=

# Your Discord ID — only this account can access the bill scheduler.
# Find it in Discord: Settings → Advanced → enable Developer Mode,
# then right-click your own username → Copy User ID.
ADMIN_DISCORD_ID=

# Discord Bot token — required for Send to DMs, Reminders, and Bill alerts.
BOT_TOKEN=

# Optional, defaults to 3000
PORT=3000
NODE_ENV=development
